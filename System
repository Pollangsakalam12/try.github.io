    <script>
        /* ================= CANVAS PARTICLE + CONSTELLATION FIELD ================= */
        const canvas = document.getElementById('field');
        const ctx = canvas.getContext('2d');
        let W, H, DPR;
        function resize() {
            DPR = Math.min(window.devicePixelRatio || 1, 2);
            W = window.innerWidth; H = window.innerHeight;
            canvas.width = W * DPR; canvas.height = H * DPR;
            canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
            ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
        }
        resize();
        window.addEventListener('resize', resize);

        const mouse = { x: window.innerWidth / 2, y: window.innerHeight / 2, active: false };
        window.addEventListener('mousemove', e => { mouse.x = e.clientX; mouse.y = e.clientY; mouse.active = true; });
        window.addEventListener('touchmove', e => { if (e.touches[0]) { mouse.x = e.touches[0].clientX; mouse.y = e.touches[0].clientY; mouse.active = true; } }, { passive: true });

        const N = window.innerWidth < 600 ? 34 : 60;
        const particles = [];
        for (let i = 0; i < N; i++) {
            particles.push({
                x: Math.random() * window.innerWidth,
                y: Math.random() * window.innerHeight,
                vx: (Math.random() - 0.5) * 0.15,
                vy: -0.08 - Math.random() * 0.12,
                r: 1 + Math.random() * 2.2,
                hue: Math.random() < 0.5 ? '201,162,39' : '201,123,132'
            });
        }

        function stepField() {
            ctx.clearRect(0, 0, W, H);
            for (const p of particles) {
                // gentle drift
                p.x += p.vx; p.y += p.vy;
                // mouse repulsion for a "living, responsive" feel
                const dx = p.x - mouse.x, dy = p.y - mouse.y;
                const dist2 = dx * dx + dy * dy;
                if (dist2 < 14000) {
                    const f = (14000 - dist2) / 14000;
                    p.x += dx * 0.01 * f; p.y += dy * 0.01 * f;
                }
                if (p.y < -10) { p.y = H + 10; p.x = Math.random() * W; }
                if (p.x < -10) p.x = W + 10;
                if (p.x > W + 10) p.x = -10;

                ctx.beginPath();
                const grad = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.r * 4);
                grad.addColorStop(0, `rgba(${p.hue},0.55)`);
                grad.addColorStop(1, `rgba(${p.hue},0)`);
                ctx.fillStyle = grad;
                ctx.arc(p.x, p.y, p.r * 4, 0, Math.PI * 2);
                ctx.fill();
            }
            // constellation lines
            for (let i = 0; i < particles.length; i++) {
                for (let j = i + 1; j < particles.length; j++) {
                    const a = particles[i], b = particles[j];
                    const dx = a.x - b.x, dy = a.y - b.y;
                    const d = Math.sqrt(dx * dx + dy * dy);
                    if (d < 130) {
                        ctx.strokeStyle = `rgba(201,162,39,${0.12 * (1 - d / 130)})`;
                        ctx.lineWidth = 0.6;
                        ctx.beginPath();
                        ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y);
                        ctx.stroke();
                    }
                }
            }
            requestAnimationFrame(stepField);
        }
        requestAnimationFrame(stepField);

        /* ================= CATCH-THE-LIGHT HIDDEN GAME ================= */
        let caught = 0;
        const CATCH_GOAL = 7;
        function tryCatch(clientX, clientY) {
            for (let i = 0; i < particles.length; i++) {
                const p = particles[i];
                const dx = p.x - clientX, dy = p.y - clientY;
                if (dx * dx + dy * dy < 22 * 22) {
                    // caught one — respawn it elsewhere so the field stays full
                    p.x = Math.random() * W; p.y = H + 10;
                    caught++;
                    playTwinkle();
                    safeVibrate(8);
                    spawnSparkle(clientX, clientY);
                    const counter = document.getElementById('catchCounter');
                    counter.textContent = `✨ ${Math.min(caught, CATCH_GOAL)}/${CATCH_GOAL}`;
                    counter.classList.add('pulse');
                    setTimeout(() => counter.classList.remove('pulse'), 300);
                    if (caught === CATCH_GOAL) {
                        unlockSecret();
                    }
                    return true;
                }
            }
            return false;
        }
        function unlockSecret() {
            const note = document.getElementById('secretNote');
            note.classList.add('unlocked');
            playUnlock();
            safeVibrate([10, 40, 10, 40, 20]);
            const r = note.getBoundingClientRect();
            burst(window.innerWidth / 2, r.top + window.scrollY ? r.top : r.top, 40);
            note.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
        canvas.style.pointerEvents = 'auto';
        canvas.addEventListener('click', e => tryCatch(e.clientX, e.clientY));
        canvas.addEventListener('touchstart', e => {
            if (e.touches[0]) tryCatch(e.touches[0].clientX, e.touches[0].clientY);
        }, { passive: true });

        /* ================= LANTERN CURSOR GLOW (eased follow) ================= */
        const lantern = document.getElementById('lantern');
        let lx = mouse.x, ly = mouse.y;
        function stepLantern() {
            lx += (mouse.x - lx) * 0.08;
            ly += (mouse.y - ly) * 0.08;
            lantern.style.left = lx + 'px';
            lantern.style.top = ly + 'px';
            if (mouse.active) lantern.classList.add('active');
            requestAnimationFrame(stepLantern);
        }
        requestAnimationFrame(stepLantern);

        /* ================= SPARKLE TRAIL ================= */
        let lastSpark = 0;
        function spawnSparkle(x, y) {
            const now = performance.now();
            if (now - lastSpark < 55) return;
            lastSpark = now;
            const s = document.createElement('div');
            s.className = 'sparkle';
            s.style.left = x + 'px'; s.style.top = y + 'px';
            document.body.appendChild(s);
            setTimeout(() => s.remove(), 950);
        }
        window.addEventListener('mousemove', e => spawnSparkle(e.clientX, e.clientY));
        window.addEventListener('touchmove', e => { if (e.touches[0]) spawnSparkle(e.touches[0].clientX, e.touches[0].clientY); }, { passive: true });

        /* ================= PHYSICS-Y CONFETTI BURST ================= */
        function burst(x, y, count = 32) {
            const colors = ['#C9A227', '#E8B9AE', '#C97B84', '#EAD08A', '#7A2E2E'];
            for (let i = 0; i < count; i++) {
                const el = document.createElement('div');
                el.className = 'burst-piece';
                const angle = Math.random() * Math.PI * 2;
                const dist = 50 + Math.random() * 110;
                const dx = Math.cos(angle) * dist, dy = Math.sin(angle) * dist - 50;
                el.style.setProperty('--bx', x + 'px');
                el.style.setProperty('--by', y + 'px');
                el.style.setProperty('--dx', dx + 'px');
                el.style.setProperty('--dy', dy + 'px');
                el.style.setProperty('--dx2', (dx + (Math.random() * 40 - 20)) + 'px');
                el.style.setProperty('--dy2', (dy + 140 + Math.random() * 60) + 'px');
                el.style.setProperty('--rot', (Math.random() * 360 - 180) + 'deg');
                el.style.setProperty('--rot2', (Math.random() * 540 - 270) + 'deg');
                el.style.setProperty('--sz', (5 + Math.random() * 5) + 'px');
                el.style.setProperty('--bc', colors[i % colors.length]);
                el.style.animationDelay = (Math.random() * 120) + 'ms';
                document.body.appendChild(el);
                setTimeout(() => el.remove(), 1800);
            }
        }

        /* ================= ENVELOPE 3D TILT ================= */
        const envelope = document.getElementById('envelope');
        envelope.addEventListener('mousemove', e => {
            const r = envelope.getBoundingClientRect();
            const px = (e.clientX - r.left) / r.width - 0.5;
            const py = (e.clientY - r.top) / r.height - 0.5;
            envelope.style.transform = `rotateY(${px * 8}deg) rotateX(${-py * 8}deg)`;
        });
        envelope.addEventListener('mouseleave', () => { envelope.style.transform = ''; });

        /* ================= KINETIC HEADLINE ================= */
        const h1 = document.getElementById('kineticH1');
        const headlineText = 'Chie 🎓';
        headlineText.split('').forEach((ch, i) => {
            const span = document.createElement('span');
            span.className = 'kletter';
            span.textContent = ch === ' ' ? '\u00A0' : ch;
            span.style.transitionDelay = (i * 45) + 'ms';
            h1.appendChild(span);
        });
        function playHeadline() {
            h1.querySelectorAll('.kletter').forEach(s => s.classList.add('in'));
            setTimeout(() => h1.classList.add('shine'), headlineText.length * 45 + 400);
        }

        /* ================= SYNTHESIZED SOUND DESIGN (no audio files needed) ================= */
        let sfxCtx = null;
        function ensureSfxCtx() {
            if (!sfxCtx) {
                try { sfxCtx = new (window.AudioContext || window.webkitAudioContext)(); }
                catch (e) { console.warn('Web Audio unavailable for sound effects', e); }
            }
            if (sfxCtx && sfxCtx.state === 'suspended') sfxCtx.resume();
            return sfxCtx;
        }
        function playCrack() {
            const ac = ensureSfxCtx(); if (!ac) return;
            const now = ac.currentTime;
            // filtered noise burst = paper/wax crack
            const bufferSize = ac.sampleRate * 0.18;
            const buf = ac.createBuffer(1, bufferSize, ac.sampleRate);
            const data = buf.getChannelData(0);
            for (let i = 0; i < bufferSize; i++) data[i] = (Math.random() * 2 - 1) * Math.pow(1 - i / bufferSize, 3);
            const noise = ac.createBufferSource(); noise.buffer = buf;
            const bp = ac.createBiquadFilter(); bp.type = 'bandpass'; bp.frequency.value = 1800; bp.Q.value = 0.8;
            const g = ac.createGain(); g.gain.setValueAtTime(0.5, now); g.gain.exponentialRampToValueAtTime(0.001, now + 0.18);
            noise.connect(bp); bp.connect(g); g.connect(ac.destination);
            noise.start(now); noise.stop(now + 0.2);
        }
        function playChime() {
            const ac = ensureSfxCtx(); if (!ac) return;
            const now = ac.currentTime;
            [880, 1318.5].forEach((freq, i) => {
                const osc = ac.createOscillator(); osc.type = 'sine'; osc.frequency.value = freq;
                const g = ac.createGain(); g.gain.setValueAtTime(0, now);
                g.gain.linearRampToValueAtTime(0.12, now + 0.02 + i * 0.05);
                g.gain.exponentialRampToValueAtTime(0.001, now + 1.1);
                osc.connect(g); g.connect(ac.destination);
                osc.start(now + i * 0.05); osc.stop(now + 1.2);
            });
        }
        function playTwinkle() {
            const ac = ensureSfxCtx(); if (!ac) return;
            const now = ac.currentTime;
            const osc = ac.createOscillator(); osc.type = 'sine';
            osc.frequency.setValueAtTime(1200, now);
            osc.frequency.exponentialRampToValueAtTime(2200, now + 0.12);
            const g = ac.createGain(); g.gain.setValueAtTime(0.1, now); g.gain.exponentialRampToValueAtTime(0.001, now + 0.18);
            osc.connect(g); g.connect(ac.destination);
            osc.start(now); osc.stop(now + 0.2);
        }
        function playUnlock() {
            const ac = ensureSfxCtx(); if (!ac) return;
            const now = ac.currentTime;
            [523.25, 659.25, 783.99, 1046.5].forEach((freq, i) => {
                const osc = ac.createOscillator(); osc.type = 'triangle'; osc.frequency.value = freq;
                const g = ac.createGain(); g.gain.setValueAtTime(0, now + i * 0.09);
                g.gain.linearRampToValueAtTime(0.1, now + i * 0.09 + 0.02);
                g.gain.exponentialRampToValueAtTime(0.001, now + i * 0.09 + 0.9);
                osc.connect(g); g.connect(ac.destination);
                osc.start(now + i * 0.09); osc.stop(now + i * 0.09 + 1);
            });
        }
        function safeVibrate(pattern) {
            try { if (navigator.vibrate) navigator.vibrate(pattern); } catch (e) { }
        }

        /* ================= TAB PEEKABOO ================= */
        const originalTitle = document.title;
        document.addEventListener('visibilitychange', () => {
            document.title = document.hidden ? 'Come back, Chie 🥺' : originalTitle;
        });

        /* ================= TIME-AWARE GREETING ================= */
        (function () {
            const h = new Date().getHours();
            let text;
            if (h < 5) text = 'Still up this late, Chie? ✨';
            else if (h < 12) text = 'Good morning, Chie ☀';
            else if (h < 18) text = 'Good afternoon, Chie 🌤';
            else text = 'Good evening, Chie 🌙';
            const el = document.getElementById('timeGreet');
            if (el) el.textContent = text;
        })();

        /* ================= AUDIO SETUP + REACTIVE WAVE ================= */
        const music = document.getElementById('bgmusic');
        const waveEl = document.getElementById('wave');
        let waveBars = [];
        const BAR_COUNT = 40;
        for (let i = 0; i < BAR_COUNT; i++) {
            const b = document.createElement('div');
            b.className = 'bar';
            waveEl.appendChild(b);
            waveBars.push(b);
        }

        let audioCtx, analyser, dataArray, audioReady = false;
        function setupAudio() {
            if (audioReady) return;
            try {
                audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                const src = audioCtx.createMediaElementSource(music);
                analyser = audioCtx.createAnalyser();
                analyser.fftSize = 128;
                dataArray = new Uint8Array(analyser.frequencyBinCount);
                src.connect(analyser);
                analyser.connect(audioCtx.destination);
                audioReady = true;
                waveEl.classList.add('visible');
                stepWave();
            } catch (err) {
                console.warn('Audio-reactive visualizer unavailable:', err);
            }
        }
        function stepWave() {
            if (!analyser) return;
            analyser.getByteFrequencyData(dataArray);
            const step = Math.floor(dataArray.length / BAR_COUNT);
            for (let i = 0; i < BAR_COUNT; i++) {
                const v = dataArray[i * step] || 0;
                waveBars[i].style.height = Math.max(4, (v / 255) * 40) + 'px';
            }
            requestAnimationFrame(stepWave);
        }

        /* ================= OPEN SEQUENCE ================= */
        const stage = document.getElementById('envelope-stage');
        const content = document.getElementById('content');
        const musicToggle = document.getElementById('music-toggle');
        let opened = false;

        envelope.addEventListener('click', () => {
            if (opened) return;
            opened = true;
            envelope.classList.add('open');
            envelope.style.transform = '';

            playCrack();
            safeVibrate([12, 30, 12]);

            const r = envelope.getBoundingClientRect();
            burst(r.left + r.width / 2, r.top + r.height * 0.42, 34);

            setupAudio();
            music.play().then(() => {
                musicToggle.classList.add('playing');
                if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();
            }).catch((err) => {
                console.warn('Music could not play — make sure music.mp3 sits next to this HTML file.', err);
            });
            musicToggle.classList.add('visible');

            setTimeout(() => { stage.classList.add('hidden'); }, 1350);
            setTimeout(() => {
                content.classList.add('show');
                playHeadline();
                playChime();
                burst(window.innerWidth / 2, 120, 46);
                document.getElementById('timeGreet').classList.add('show');
                const hint = document.getElementById('catchHint');
                const counter = document.getElementById('catchCounter');
                hint.classList.add('show');
                counter.classList.add('show');
                setTimeout(() => hint.classList.add('fade-out'), 6500);
            }, 1650);
        });

        musicToggle.addEventListener('click', () => {
            if (music.paused) {
                setupAudio();
                music.play().then(() => {
                    musicToggle.classList.add('playing');
                    if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();
                });
            } else {
                music.pause();
                musicToggle.classList.remove('playing');
            }
        });

        /* magnetic hover on music toggle */
        musicToggle.addEventListener('mousemove', e => {
            const r = musicToggle.getBoundingClientRect();
            const mx = e.clientX - (r.left + r.width / 2);
            const my = e.clientY - (r.top + r.height / 2);
            musicToggle.style.transform = `translate(${mx * 0.25}px, ${my * 0.25}px)`;
        });
        musicToggle.addEventListener('mouseleave', () => { musicToggle.style.transform = ''; });

        /* ================= SCROLL REVEAL ================= */
        const io = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) { entry.target.classList.add('in-view'); io.unobserve(entry.target); }
            });
        }, { threshold: 0.2 });
        document.querySelectorAll('.reveal-p, #footerSig').forEach(el => io.observe(el));

        const polaroidIO = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    setTimeout(() => entry.target.classList.add('developed'), 350);
                    polaroidIO.unobserve(entry.target);
                }
            });
        }, { threshold: 0.4 });
        polaroidIO.observe(document.getElementById('photoFrame'));

        /* ================= SCROLL PROGRESS BAR ================= */
        const progress = document.getElementById('progress');
        window.addEventListener('scroll', () => {
            const h = document.documentElement.scrollHeight - window.innerHeight;
            const pct = h > 0 ? (window.scrollY / h) * 100 : 0;
            progress.style.width = pct + '%';
        }, { passive: true });

        /* ================= PHOTO TILT ================= */
        const photoFrame = document.getElementById('photoFrame');
        photoFrame.addEventListener('mousemove', e => {
            const r = photoFrame.getBoundingClientRect();
            const px = (e.clientX - r.left) / r.width - 0.5;
            const py = (e.clientY - r.top) / r.height - 0.5;
            photoFrame.style.transform = `rotate(-2.5deg) rotateY(${px * 10}deg) rotateX(${-py * 10}deg)`;
        });
        photoFrame.addEventListener('mouseleave', () => { photoFrame.style.transform = 'rotate(-2.5deg)'; });
    </script>

</body>

</html>